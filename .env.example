# ─────────────────────────────────────────────
# InstantLocalBusiness.com — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# Your production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://instantlocalbusiness.com

# Google Search Console verification code (optional)
# Get from: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# OpenAI API key (for AI site generation - future feature)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Stripe keys (for payments - future feature)
# Get from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend API key (for transactional email - future feature)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# Analytics (optional - privacy-friendly)
# Get from: https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=instantlocalbusiness.com
